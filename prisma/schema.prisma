generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id            String   @id @default(cuid())
  title         String
  description   String?
  location      String
  city          String
  state         String
  country       String   @default("India")
  price         Float
  currency      String   @default("INR")
  beds          Int?
  baths         Int?
  sqft          Float?
  propertyType  String
  listingType   String
  reraNumber    String?
  aiScore       Float?
  images        String[]
  amenities     String[]
  documents     Json     @default("[]")
  status        String   @default("pending")
  featured      Boolean  @default(false)
  verified      Boolean  @default(false)
  reraVerified  Boolean  @default(false)
  realPhotos    Boolean  @default(false)
  accuratePrice Boolean  @default(false)
  ownerConsent  Boolean  @default(false)
  // Granular honesty-first verification checks shown via the PropKnown Verified stamp —
  // shape matches components/ui/VerificationBadge.tsx's VerificationFlags.
  verificationFlags Json @default("{}")
  // Legal Safety Checklist (Feature: Legal Shield) — shape matches lib/legalShield.ts's
  // LegalChecklist (Record<itemKey, "verified"|"pending"|"na">). Admin-set only.
  legalChecklist Json @default("{}")
  legalNotes     String?
  // Construction Progress Tracker — array of { id, title, note, photoUrl?, date, pctComplete }
  // milestones, newest last. Only shown for listingType/status "under construction".
  constructionMilestones Json @default("[]")
  constructionPct        Int?
  expectedCompletion     String?
  // NRI virtual tour — external video URL (YouTube/Drive link), admin-provided
  videoTourUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  leads         Lead[]
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  email        String?
  phone        String
  message      String?
  source       String
  status       String    @default("new")
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  notes        String?
  assignedTo   String?
  followUpDate DateTime?
  leadValue    Float?
  tags         String[]
  timeline     Json      @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("agent")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UploadedFile {
  id        String   @id @default(cuid())
  name      String
  mimeType  String
  sizeBytes Int
  data      String   @db.Text
  docType   String?
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BuyerUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  passwordHash String
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  alerts       Alert[]
}

model Favorite {
  id           String    @id @default(cuid())
  buyerId      String
  buyer        BuyerUser @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  listingId    String
  title        String
  priceDisplay String?
  location     String?
  image        String?
  createdAt    DateTime  @default(now())

  @@unique([buyerId, listingId])
}

model Alert {
  id        String    @id @default(cuid())
  buyerId   String
  buyer     BuyerUser @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  city      String?
  propType  String?
  minBudget Float?
  maxBudget Float?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}

model PropertySubmission {
  id           String   @id @default(cuid())
  title        String
  propType     String
  bhk          String?
  size         String?
  sizeUnit     String?
  priceDisplay String
  city         String
  area         String
  description  String   @db.Text
  features     String?
  reraNumber   String?
  ownerName    String
  ownerPhone   String
  ownerEmail   String
  photoIds     String   @default("[]") @db.Text
  videoIds     String   @default("[]") @db.Text
  videoUrls    String   @default("[]") @db.Text
  docIds       String   @default("[]") @db.Text
  status       String   @default("pending")
  rejectReason String?
  adminNotes   String?
  // Granular honesty-first verification checks shown via the PropKnown Verified stamp —
  // shape matches components/ui/VerificationBadge.tsx's VerificationFlags. Admin-toggled
  // in the submission review UI; never auto-set to true.
  verificationFlags Json @default("{}")
  // Legal Safety Checklist (Feature: Legal Shield) — shape matches lib/legalShield.ts's
  // LegalChecklist (Record<itemKey, "verified"|"pending"|"na">). Admin-set only.
  legalChecklist Json @default("{}")
  legalNotes     String?
  // Construction Progress Tracker — array of { id, title, note, photoUrl?, date, pctComplete }
  // milestones, newest last. Only shown for propType/status implying under-construction.
  constructionMilestones Json @default("[]")
  constructionPct        Int?
  expectedCompletion     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Server-side counter for the anonymous "3 free AI checks" limit (AI Intelligence, Price
// Reality Check). Keyed by a random ID stored in an httpOnly cookie -- a real database
// counter rather than in-memory, since in-memory state isn't reliably shared across
// serverless invocations and would make the limit meaningless in production. Logged-in
// buyers never touch this table at all (see lib/usageLimit.ts).
model AnonymousUsage {
  id        String   @id
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Dedicated free-search counter + lead-gate flag for the AI Intelligence page only --
// deliberately separate from AnonymousUsage (shared by Price Reality Check) so a visitor's
// AI Intelligence budget isn't silently eaten by using a different tool. Keyed the same way:
// a random ID in an httpOnly cookie. Once `registered` is true (visitor submitted the
// lead-capture gate), they get unlimited searches from then on -- see lib/aiIntelGate.ts.
model AiIntelUsage {
  id         String   @id
  count      Int      @default(0)
  registered Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// IP-keyed fallback counter, checked alongside AiIntelUsage's cookie-keyed one -- a visitor
// is only let through if BOTH are under budget (or either is registered). Cookie-only tracking
// resets for free the moment someone clears cookies or opens a private window; this closes
// that specific gap without pretending to be a hard, unbeatable wall (a shared office/NAT IP,
// VPN, or mobile carrier CGNAT can still legitimately share one IP across many real visitors --
// same honesty-over-security-theater tradeoff already used elsewhere in this file).
model AiIntelUsageByIp {
  ip         String   @id
  count      Int      @default(0)
  registered Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
