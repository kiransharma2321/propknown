generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id            String   @id @default(cuid())
  title         String
  description   String?
  location      String
  city          String
  state         String
  country       String   @default("India")
  price         Float
  currency      String   @default("INR")
  beds          Int?
  baths         Int?
  sqft          Float?
  propertyType  String
  listingType   String
  reraNumber    String?
  aiScore       Float?
  images        String[]
  amenities     String[]
  documents     Json     @default("[]")
  status        String   @default("pending")
  featured      Boolean  @default(false)
  verified      Boolean  @default(false)
  reraVerified  Boolean  @default(false)
  realPhotos    Boolean  @default(false)
  accuratePrice Boolean  @default(false)
  ownerConsent  Boolean  @default(false)
  // Granular honesty-first verification checks shown via the PropKnown Verified stamp —
  // shape matches components/ui/VerificationBadge.tsx's VerificationFlags.
  verificationFlags Json @default("{}")
  // Legal Safety Checklist (Feature: Legal Shield) — shape matches lib/legalShield.ts's
  // LegalChecklist (Record<itemKey, "verified"|"pending"|"na">). Admin-set only.
  legalChecklist Json @default("{}")
  legalNotes     String?
  // Construction Progress Tracker — array of { id, title, note, photoUrl?, date, pctComplete }
  // milestones, newest last. Only shown for listingType/status "under construction".
  constructionMilestones Json @default("[]")
  constructionPct        Int?
  expectedCompletion     String?
  // NRI virtual tour — external video URL (YouTube/Drive link), admin-provided
  videoTourUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  leads         Lead[]

  // Enterprise CRM: AI scoring (Section 5 / Section G-Q) -- aiScore above is reused as the
  // headline investment score; these are the supporting figures computeMarketIntel() and the
  // legal-heuristic scorer produce alongside it. All nullable -- unset until "Score this
  // property" is run, never fabricated.
  aiPricePrediction Json?
  legalScore        Float?
  roiAnalysis       Json?
  aiScoredAt        DateTime?

  siteVisits    SiteVisit[]
  bookings      Booking[]

  @@index([status])
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  email        String?
  phone        String
  message      String?
  source       String
  status       String    @default("new")
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  notes        String?
  assignedTo   String?
  followUpDate DateTime?
  leadValue    Float?
  tags         String[]
  timeline     Json      @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Documents attached in Lead Detail -- same JSON-array-of-UploadedFile-id pattern already
  // used by PropertySubmission's photoIds/videoIds/docIds, not a real FK (UploadedFile has no
  // relation column; every existing usage in this codebase resolves IDs manually instead).
  docIds       String    @default("[]") @db.Text

  // Enterprise CRM: AI Lead Scoring (Section 3). All nullable, all written only by the
  // "Score this lead" action -- never auto-populated, never fabricated. recommendedPropertyId
  // is a soft reference (Property IDs live in a separate space from PropertySubmission's, same
  // caveat as propertyId above), resolved for display, not a DB-enforced FK.
  leadScore              Float?
  buyingIntent           String?
  financialStrength      String?
  urgencyLevel           String?
  conversionProbability  Float?
  bestFollowUpTime       String?
  recommendedPropertyId  String?
  nextBestAction         String?
  aiSummary              String?
  aiScoredAt             DateTime?

  // Channel Partner attribution (Section 9) -- optional, only set when a lead was shared by
  // a registered partner.
  partnerId    String?
  partner      ChannelPartner? @relation(fields: [partnerId], references: [id])

  siteVisits   SiteVisit[]
  bookings     Booking[]

  @@index([status])
  @@index([assignedTo])
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("agent")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resetTokens  PasswordResetToken[]
}

// Forgot-password tokens for /admin and /crm (all roles). The raw token is only ever emailed
// to the user -- tokenHash (sha256 of the raw token) is what's stored, so a DB read alone
// never yields a usable token. Single-use (`used`) and short-lived (`expiresAt`).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UploadedFile {
  id        String   @id @default(cuid())
  name      String
  mimeType  String
  sizeBytes Int
  data      String   @db.Text
  docType   String?
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BuyerUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  passwordHash String
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  alerts       Alert[]
}

model Favorite {
  id           String    @id @default(cuid())
  buyerId      String
  buyer        BuyerUser @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  listingId    String
  title        String
  priceDisplay String?
  location     String?
  image        String?
  createdAt    DateTime  @default(now())

  @@unique([buyerId, listingId])
}

model Alert {
  id        String    @id @default(cuid())
  buyerId   String
  buyer     BuyerUser @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  city      String?
  propType  String?
  minBudget Float?
  maxBudget Float?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}

model PropertySubmission {
  id           String   @id @default(cuid())
  title        String
  propType     String
  bhk          String?
  size         String?
  sizeUnit     String?
  priceDisplay String
  city         String
  area         String
  description  String   @db.Text
  features     String?
  reraNumber   String?
  ownerName    String
  ownerPhone   String
  ownerEmail   String
  photoIds     String   @default("[]") @db.Text
  // Keyed by photoId (from photoIds above), not array position -- { [photoId]: "caption text" }.
  // Owner-written at submission time, optional. Used as the photo's alt text in the gallery
  // instead of a generic repeated title/description when present for that specific photo.
  photoCaptions Json    @default("{}")
  videoIds     String   @default("[]") @db.Text
  videoUrls    String   @default("[]") @db.Text
  docIds       String   @default("[]") @db.Text
  status       String   @default("pending")
  rejectReason String?
  adminNotes   String?
  // Granular honesty-first verification checks shown via the PropKnown Verified stamp —
  // shape matches components/ui/VerificationBadge.tsx's VerificationFlags. Admin-toggled
  // in the submission review UI; never auto-set to true.
  verificationFlags Json @default("{}")
  // Legal Safety Checklist (Feature: Legal Shield) — shape matches lib/legalShield.ts's
  // LegalChecklist (Record<itemKey, "verified"|"pending"|"na">). Admin-set only.
  legalChecklist Json @default("{}")
  legalNotes     String?
  // Construction Progress Tracker — array of { id, title, note, photoUrl?, date, pctComplete }
  // milestones, newest last. Only shown for propType/status implying under-construction.
  constructionMilestones Json @default("[]")
  constructionPct        Int?
  expectedCompletion     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Server-side counter for the anonymous "3 free AI checks" limit (AI Intelligence, Price
// Reality Check). Keyed by a random ID stored in an httpOnly cookie -- a real database
// counter rather than in-memory, since in-memory state isn't reliably shared across
// serverless invocations and would make the limit meaningless in production. Logged-in
// buyers never touch this table at all (see lib/usageLimit.ts).
model AnonymousUsage {
  id        String   @id
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Dedicated free-search counter + lead-gate flag for the AI Intelligence page only --
// deliberately separate from AnonymousUsage (shared by Price Reality Check) so a visitor's
// AI Intelligence budget isn't silently eaten by using a different tool. Keyed the same way:
// a random ID in an httpOnly cookie. Once `registered` is true (visitor submitted the
// lead-capture gate), they get unlimited searches from then on -- see lib/aiIntelGate.ts.
model AiIntelUsage {
  id         String   @id
  count      Int      @default(0)
  registered Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// IP-keyed fallback counter, checked alongside AiIntelUsage's cookie-keyed one -- a visitor
// is only let through if BOTH are under budget (or either is registered). Cookie-only tracking
// resets for free the moment someone clears cookies or opens a private window; this closes
// that specific gap without pretending to be a hard, unbeatable wall (a shared office/NAT IP,
// VPN, or mobile carrier CGNAT can still legitimately share one IP across many real visitors --
// same honesty-over-security-theater tradeoff already used elsewhere in this file).
model AiIntelUsageByIp {
  ip         String   @id
  count      Int      @default(0)
  registered Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Precomputed AI Intelligence results for the "hot market" locations (lib/hotMarkets.ts) x all
// property types, refreshed every few hours by app/api/cron/refresh-hot-markets. Lets the
// server-rendered /ai-intelligence/[city]/[area] overview pages render instantly with zero live
// Gemini/Tavily calls and be crawled by Google without any JS or gate involved, and lets
// app/api/market-intel/overview serve a full multi-type location overview for free on a cache
// hit. `id` is a deterministic composite key so refreshing is always a plain upsert, never a
// duplicate row. `data` stores the exact same normalised shape computeMarketIntel() always
// returns (lib/marketIntel.ts) -- this table is a cache of that function's output, not a
// separately-shaped summary.
model HotMarketCache {
  id           String   @id // `${city}|${area}|${propertyType}`
  city         String
  area         String
  propertyType String
  unit         String
  data         Json
  updatedAt    DateTime @updatedAt

  @@index([city, area])
}

// ─────────────────────────────────────────────────────────────────────────────
// Enterprise CRM extension (feature/crm-enterprise-full) -- everything below this line is
// additive: new tables only, plus the nullable fields added to Property/Lead above. Nothing
// existing was changed or removed.
// ─────────────────────────────────────────────────────────────────────────────

// Site Visit Module (Section 6) -- basic scheduling/status/feedback tonight. Deliberately no
// live GPS tracking field (mapsLink is a plain "open in Google Maps" deep link, not a tracked
// device location) and no aiSummary field yet -- both deferred per the plan.
model SiteVisit {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
  scheduledAt DateTime
  assignedTo  String?
  status      String    @default("scheduled") // scheduled | completed | cancelled | no_show
  feedback    String?
  rating      Int?
  mapsLink    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
}

// Booking Module (Section 7) -- basic record + status/timeline tonight. Deliberately no
// agreement/cancellation/refund fields -- that's real financial workflow logic, excluded from
// tonight's scope on purpose (see plan).
model Booking {
  id         String    @id @default(cuid())
  leadId     String
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  amount     Float?
  status     String    @default("initiated") // initiated | confirmed | cancelled
  timeline   Json      @default("[]")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([leadId])
}

// Channel Partner Module (Section 9) -- registration + lead attribution tonight. Commission
// model exists for the future payout-tracking feature but nothing writes to it yet -- no
// commission calculation logic is built in this pass (financial logic, deliberately excluded).
model ChannelPartner {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  company   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  leads       Lead[]
  commissions Commission[]
}

model Commission {
  id        String         @id @default(cuid())
  partnerId String
  partner   ChannelPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  leadId    String?
  amount    Float?
  status    String         @default("pending")
  createdAt DateTime       @default(now())
}

// Marketing (Section 10) -- real campaign records with manually-entered spend, so cost-per-lead
// can be computed from real numbers (spend ÷ real Lead.source-attributed count) rather than
// fabricated. No landing-page builder or automated spend tracking.
model Campaign {
  id        String    @id @default(cuid())
  name      String
  channel   String // "meta" | "google_ads" | "youtube" | "other"
  spend     Float?
  startDate DateTime?
  endDate   DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Audit Trail (Section 14) -- scoped to new Enterprise CRM mutations only tonight (Settings
// changes, AI scoring runs, new role/user creation). Deliberately not retrofitted onto every
// pre-existing route -- see plan for why.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actorName String?
  action    String
  entity    String?
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── Settings (Section 15) -- real, persisted, editable config, replacing the previously
// static/hardcoded admin Settings tab. ───────────────────────────────────────────────────────

model CompanySettings {
  id          String   @id @default("singleton")
  companyName String?
  founderName String?
  whatsapp    String?
  email       String?
  address     String?
  updatedAt   DateTime @updatedAt
}

model LeadSource {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Project {
  id        String   @id @default(cuid())
  name      String
  builder   String?
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Builder {
  id        String   @id @default(cuid())
  name      String   @unique
  contact   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Bank {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PropertyTypeConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// API Keys (Section 15) -- Meta/Google Ads/etc credentials. encryptedValue is AES-encrypted
// JSON (see lib/apiCredentials.ts), never the raw secret -- the API route that reads this for
// display purposes only ever returns a masked placeholder, never the decrypted value, per the
// "never display plaintext once saved" requirement.
model ApiCredential {
  id           String    @id @default(cuid())
  provider     String    @unique // "meta" | "google_ads" | "youtube"
  encryptedValue String  @db.Text
  status       String    @default("not_connected") // not_connected | connected | error
  lastTestedAt DateTime?
  updatedAt    DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Employee Training Tracker (new feature) -- links + completion tracking only, deliberately
// no quiz/certification system. TrainingItem is admin-authored content (a link, not a file --
// video/document links live wherever the admin hosts them, e.g. YouTube/Google Drive).
// TrainingAssignment is per-employee (assigneeId references AdminUser.id, not enforced as a
// DB-level FK since AdminUser rows can be soft-deleted/deactivated and we want assignment
// history to survive that, same reasoning as Lead.assignedTo being a bare string elsewhere).
// ─────────────────────────────────────────────────────────────────────────────

model TrainingItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  link        String
  linkType    String   @default("other") // "video" | "document" | "other" -- display hint only
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments TrainingAssignment[]
}

model TrainingAssignment {
  id             String       @id @default(cuid())
  trainingItemId String
  trainingItem   TrainingItem @relation(fields: [trainingItemId], references: [id], onDelete: Cascade)
  assigneeId     String       // AdminUser.id -- soft reference, see note above
  assigneeName   String       // denormalised at assignment time so completion dashboards don't
                               // break if the assignee is later deactivated/renamed
  completed      Boolean      @default(false)
  completedAt    DateTime?
  assignedAt     DateTime     @default(now())

  @@unique([trainingItemId, assigneeId])
  @@index([assigneeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sales Champions Leaderboard (new feature) -- no new table needed. Ranking is computed live
// from real Lead data (status="won", assignedTo, leadValue) via the same aggregation pattern
// already used by the Executive Dashboard's "Top Sales Executives" card -- see
// app/api/crm/leaderboard/route.ts. Kept here as a note so the absence of a Leaderboard model
// isn't mistaken for an oversight.
// ─────────────────────────────────────────────────────────────────────────────
