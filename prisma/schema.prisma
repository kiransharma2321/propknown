generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id            String   @id @default(cuid())
  title         String
  description   String?
  location      String
  city          String
  state         String
  country       String   @default("India")
  price         Float
  currency      String   @default("INR")
  beds          Int?
  baths         Int?
  sqft          Float?
  propertyType  String
  listingType   String
  reraNumber    String?
  aiScore       Float?
  images        String[]
  amenities     String[]
  documents     Json     @default("[]")
  status        String   @default("pending")
  featured      Boolean  @default(false)
  verified      Boolean  @default(false)
  reraVerified  Boolean  @default(false)
  realPhotos    Boolean  @default(false)
  accuratePrice Boolean  @default(false)
  ownerConsent  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  leads         Lead[]
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  email        String?
  phone        String
  message      String?
  source       String
  status       String    @default("new")
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id])
  notes        String?
  assignedTo   String?
  followUpDate DateTime?
  leadValue    Float?
  tags         String[]
  timeline     Json      @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("agent")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UploadedFile {
  id        String   @id @default(cuid())
  name      String
  mimeType  String
  sizeBytes Int
  data      String   @db.Text
  docType   String?
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BuyerUser {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  passwordHash String
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  alerts       Alert[]
}

model Favorite {
  id           String    @id @default(cuid())
  buyerId      String
  buyer        BuyerUser @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  listingId    String
  title        String
  priceDisplay String?
  location     String?
  image        String?
  createdAt    DateTime  @default(now())

  @@unique([buyerId, listingId])
}

model Alert {
  id        String    @id @default(cuid())
  buyerId   String
  buyer     BuyerUser @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  city      String?
  propType  String?
  minBudget Float?
  maxBudget Float?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}

model PropertySubmission {
  id           String   @id @default(cuid())
  title        String
  propType     String
  bhk          String?
  size         String?
  sizeUnit     String?
  priceDisplay String
  city         String
  area         String
  description  String   @db.Text
  features     String?
  reraNumber   String?
  ownerName    String
  ownerPhone   String
  ownerEmail   String
  photoIds     String   @default("[]") @db.Text
  videoIds     String   @default("[]") @db.Text
  videoUrls    String   @default("[]") @db.Text
  docIds       String   @default("[]") @db.Text
  status       String   @default("pending")
  rejectReason String?
  adminNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
